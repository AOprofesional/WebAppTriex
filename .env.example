# ============================================================
# SUPABASE - Credenciales del proyecto
# Obtener desde: https://supabase.com/dashboard > Project Settings > API
# ============================================================
VITE_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# ============================================================
# GEMINI API
# Obtener desde: https://makersuite.google.com/app/apikey
# ============================================================
GEMINI_API_KEY=TU_GEMINI_API_KEY

# ============================================================
# CONTACTO - WhatsApp (número en formato internacional sin +)
# Ejemplo: Argentina 54 + código área sin 0 + número sin 15
# ============================================================
VITE_SUPPORT_WHATSAPP=549XXXXXXXXXX
VITE_ADMIN_WHATSAPP=549XXXXXXXXXX

# ============================================================
# CONTACTO - Emails
# ============================================================
VITE_SUPPORT_EMAIL=soporte@tudominio.com
VITE_ADMIN_SUPPORT_EMAIL=admin@tudominio.com
VITE_VAPID_EMAIL=no_reply@tudominio.com
